# Normalize line endings to LF on commit, regardless of the contributor's OS.
# Prevents bash scripts (./setup) from breaking when checked out on Windows
# and committed back with CRLF endings.
* text=auto eol=lf

# Shell scripts must always be LF — they break otherwise.
*.sh text eol=lf
setup text eol=lf

# Python and markdown — LF.
*.py text eol=lf
*.md text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
