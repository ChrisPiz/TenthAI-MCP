# Required: Anthropic API key for the 9 frame agents + tenth-man dissenter.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Embedding provider: OpenAI text-embedding-3-small.
# ~USD 0.0005/run. Most devs already have a key.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Advanced opt-in: Voyage embeddings (higher Spanish quality).
# WARNING: Voyage's free tier (3 RPM / 10K TPM, no payment method) cannot
# complete a single Henge run — one run embeds 10 advisor responses in one
# call and trips the TPM cap. Add a payment method on
# https://dashboard.voyageai.com/ first (200M free tokens/month still apply).
# Then uncomment both lines below.
# VOYAGE_API_KEY=pa-...
# EMBED_PROVIDER=voyage

# Optional: report chrome locale. Leave unset to auto-detect from each
# question (Spanish question → Spanish report; English → English report).
# Force a single language by setting:
#   HENGE_LOCALE=en
#   HENGE_LOCALE=es
# HENGE_LOCALE=en
